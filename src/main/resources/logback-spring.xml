<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Import Spring Boot default configuration -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Define the masking pattern layout -->
    <appender name="CONSOLE_MASKED" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.oleksii.surovtsev.portfolio.config.LoggingConfiguration$MaskingPatternLayout">
                <pattern>
                    %clr(%d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd HH:mm:ss.SSS}}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}
                </pattern>
            </layout>
        </encoder>
    </appender>

    <!-- Define file appender with masking -->
    <appender name="FILE_MASKED" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/portfolio.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/portfolio-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.oleksii.surovtsev.portfolio.config.LoggingConfiguration$MaskingPatternLayout">
                <pattern>
                    %d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n
                </pattern>
            </layout>
        </encoder>
    </appender>

    <!-- Spring profiles -->
    <springProfile name="dev,default">
        <root level="INFO">
            <appender-ref ref="CONSOLE_MASKED"/>
            <appender-ref ref="FILE_MASKED"/>
        </root>
        <logger name="com.oleksii.surovtsev.portfolio" level="DEBUG"/>
        <logger name="org.atmosphere" level="WARN"/>
        <logger name="com.sendgrid" level="INFO"/>
    </springProfile>

    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="CONSOLE_MASKED"/>
            <appender-ref ref="FILE_MASKED"/>
        </root>
        <logger name="com.oleksii.surovtsev.portfolio" level="INFO"/>
        <logger name="org.atmosphere" level="WARN"/>
        <logger name="com.sendgrid" level="WARN"/>
    </springProfile>

    <!-- Specific logger to prevent logging sensitive data from certain packages -->
    <logger name="com.sendgrid.SendGrid" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE_MASKED"/>
        <appender-ref ref="FILE_MASKED"/>
    </logger>
</configuration>